# ── Primus zkTLS ─────────────────────────────────────────────
# Get these from https://dev.primuslabs.xyz after creating a project
PRIMUS_APP_ID=your_primus_app_id
PRIMUS_APP_SECRET=your_primus_app_secret

# ── Virtuals ACP ──────────────────────────────────────────────
# From https://app.virtuals.io/acp/join
AGENT_WALLET_ADDRESS=0x...
SESSION_ENTITY_KEY_ID=1
WALLET_PRIVATE_KEY=0x...

# ── LLM API Keys ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Chain (Base) ──────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=your_basescan_key

# ── Optional on-chain verification / deployment inputs ───────
# Primus verifier address is intentionally not hardcoded in this repo.
PRIMUS_VERIFIER_ADDRESS=0x...
MAX_ATTESTATION_AGE_SECS=600

# ── TrustLayer Contracts ──────────────────────────────────────
# After deployment
TRUST_LAYER_VERIFIER_ADDRESS=0x...
TRUST_LAYER_ACP_HOOK_ADDRESS=0x...
