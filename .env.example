# ── Primus zkTLS ─────────────────────────────────────────────
# Get these from https://dev.primuslabs.xyz after creating a project
PRIMUS_APP_ID=your_primus_app_id
PRIMUS_APP_SECRET=your_primus_app_secret

# ── Virtuals ACP ──────────────────────────────────────────────
# From https://app.virtuals.io/acp/join
AGENT_WALLET_ADDRESS=0x...
SESSION_ENTITY_KEY_ID=1
WALLET_PRIVATE_KEY=0x...

# ── LLM API Keys ──────────────────────────────────────────────
# Live test script defaults to GLM-5 on Base Sepolia.
ZAI_API_KEY=sk-...
ZAI_MODEL=glm-5
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...

# ── Chain (Base) ──────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=your_basescan_key

# ── Optional on-chain verification / deployment inputs ───────
# Official Primus zkTLS verifier contract (same address on Base mainnet & Sepolia)
# https://docs.primuslabs.xyz
PRIMUS_VERIFIER_ADDRESS=0xC02234058caEaA9416506eABf6Ef3122fCA939E8
MAX_ATTESTATION_AGE_SECS=600
TRUST_LAYER_NETWORK=base_sepolia
TRUST_LAYER_RPC_URL=

# ── TrustLayer Contracts ──────────────────────────────────────
# Required for live on-chain verification / after deployment
# Prefer the network-specific variables when testing on Base Sepolia.
BASE_SEPOLIA_TRUST_LAYER_VERIFIER_ADDRESS=0x...
BASE_SEPOLIA_TRUST_LAYER_ACP_HOOK_ADDRESS=0x...
TRUST_LAYER_VERIFIER_ADDRESS=0x...
TRUST_LAYER_ACP_HOOK_ADDRESS=0x...

# ── Evaluator Policy ─────────────────────────────────────────
# For the live test script: evaluator address whose IEvaluatorPolicy
# contract is registered on the hook via setPolicy().
EVALUATOR_ADDRESS=0x...
# For deploy-policy.cjs:
POLICY_CONTRACT=FactCheckPolicy
POLICY_MAX_AGE_SECS=600
POLICY_TRUSTED_DOMAINS=reuters.com,apnews.com,api.openai.com,api.z.ai

# ── Buyer (Evaluator wallet) ─────────────────────────────────
BUYER_PRIVATE_KEY=0x...
