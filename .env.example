# ── Primus zkTLS ─────────────────────────────────────────────
# Get these from https://dev.primuslabs.xyz after creating a project
PRIMUS_APP_ID=your_primus_app_id
PRIMUS_APP_SECRET=your_primus_app_secret

# ── Provider / Evaluator Wallets ──────────────────────────────
AGENT_WALLET_ADDRESS=0x...
WALLET_PRIVATE_KEY=0x...

# ── LLM API Keys ──────────────────────────────────────────────
# Live test script defaults to GLM-5 on Base Sepolia.
ZAI_API_KEY=sk-...
ZAI_MODEL=glm-5
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...

# ── Chain (Base) ──────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=your_basescan_key

# ── Optional on-chain verification / deployment inputs ───────
# Official Primus zkTLS verifier contract (same address on Base mainnet & Sepolia)
# https://docs.primuslabs.xyz/enterprise/onchain-interaction/overview
PRIMUS_VERIFIER_ADDRESS=0xCE7cefB3B5A7eB44B59F60327A53c9Ce53B0afdE
MAX_ATTESTATION_AGE_SECS=600
VERITAS_NETWORK=base_sepolia
VERITAS_RPC_URL=

# ── Veritas + ERC-8183 Contracts ───────────────────────────
# Required for live on-chain verification / after deployment.
# VeritasVerifier may already be deployed; the ERC-8183 hook address depends
# on your own AgenticCommerce deployment.
BASE_SEPOLIA_VERITAS_VERIFIER_ADDRESS=0x5D39Ef731fDfd3d49D033724d70be0FD0E31172c
VERITAS_VERIFIER_ADDRESS=0x5D39Ef731fDfd3d49D033724d70be0FD0E31172c
BASE_SEPOLIA_VERITAS_8183_HOOK_ADDRESS=0x...
VERITAS_8183_HOOK_ADDRESS=0x...
ERC8183_AGENTIC_COMMERCE_ADDRESS=0x...
BASE_SEPOLIA_ERC8183_AGENTIC_COMMERCE_ADDRESS=0x...

# ── Evaluator Policy ─────────────────────────────────────────
# Evaluator address whose IEvaluatorPolicy contract is registered on the hook.
EVALUATOR_ADDRESS=0xDbbD7239947Bfe3320e98B937CDBF7553Bceb0Bd
# For deploy-policy.cjs:
# - FactCheckPolicy: reuters.com,apnews.com,api.openai.com,api.z.ai
# - TokenAnalysisPolicy: api.coingecko.com,api.z.ai
POLICY_CONTRACT=FactCheckPolicy
POLICY_MAX_AGE_SECS=600
POLICY_TRUSTED_DOMAINS=reuters.com,apnews.com,api.openai.com,api.z.ai

# ── Evaluator wallet ──────────────────────────────────────────
BUYER_PRIVATE_KEY=0x...

# ── Token Analysis Example ────────────────────────────────────
COINGECKO_VS_CURRENCY=usd
TOKEN_ANALYSIS_DEFAULT_DAYS=90
